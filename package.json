{
  "name": "genesis-backend-messenger",
  "version": "0.1.0",
  "private": true,
  "description": "Corporate messenger backend built with NestJS, Prisma and PostgreSQL",
  "license": "MIT",
  "scripts": {
    "dev:backend": "npm run start:dev -w apps/backend",
    "build:backend": "npm run build -w apps/backend",
    "start:backend": "npm run start -w apps/backend",
    "start:backend:prod": "npm run start:prod -w apps/backend",

    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker logs -f genesis-messenger-postgres",
    "db:restart": "docker compose restart postgres",

    "prisma:generate": "npm run prisma:generate -w apps/backend",
    "prisma:migrate": "npm run prisma:migrate -w apps/backend",
    "prisma:studio": "npm run prisma:studio -w apps/backend",
    "prisma:seed": "npm run prisma:seed -w apps/backend"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}